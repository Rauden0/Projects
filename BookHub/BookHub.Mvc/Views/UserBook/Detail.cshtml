@using BookHub.Mvc.Models.User
@using DataAccessLayer.Enums
@model BookDetailViewModel

@{
    ViewData["Title"] = Model.Book.Name;
    var book = Model.Book;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

<div class="container mt-4">
    <div class="row g-4">
        <div class="col-md-5">
            <div class="border rounded p-2 bg-light shadow-sm">
                <img src="@GetImageSrc(book.ImageBase64)"
                     class="img-fluid w-100 rounded"
                     alt="@book.Name" />
            </div>
        </div>

        <div class="col-md-7">
            <h1 class="mb-2">@book.Name</h1>
            <div class="text-muted mb-3">
                @if (!string.IsNullOrWhiteSpace(Model.AuthorsText))
                {
                    <div><strong>Author:</strong> @Model.AuthorsText</div>
                }
                @if (!string.IsNullOrWhiteSpace(book.PrimaryGenre?.Name))
                {
                    <div><strong>Primary genre:</strong> @book.PrimaryGenre!.Name</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.GenresText))
                {
                    <div><strong>Genre:</strong> @Model.GenresText</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.PublisherText))
                {
                    <div><strong>Publisher:</strong> @Model.PublisherText</div>
                }
            </div>

            <div class="fs-4 fw-bold mb-3 text-primary">
                @book.Price.ToString("0.00") Kč
            </div>

            <div class="mb-3 fw-semibold">
                @if (book.StockQuantity > 0)
                {
                    <span class="text-success"><i class="bi bi-check-circle"></i> In stock (@book.StockQuantity pcs)</span>
                }
                else
                {
                    <span class="text-danger"><i class="bi bi-x-circle"></i> Out of stock</span>
                }
            </div>

            <hr />
            <p style="white-space: pre-line;" class="text-secondary">@book.Description</p>
            
            <div class="mt-4">
                @if (isAuthenticated) {
                    <div class="d-flex gap-2">
                    <a class="btn btn-primary flex-fill" asp-controller="UserBook" asp-action="AddToCartFromDetail" asp-route-id="@book.Id">
                        <i class="bi bi-cart-plus"></i> Add to cart
                    </a>
                    <div class="dropdown flex-fill">
                        <a class="btn btn-primary dropdown-toggle w-100"
                           type="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            Add to wishlist
                        </a>
                        <ul class="dropdown-menu" style="width: max-content;">
                            @foreach (var wl in Model.WishLists)
                            {
                                <li>
                                    <form asp-controller="UserBook"
                                          asp-action="AddToWishListFromDetail"
                                          method="post" class="px-3">

                                        <input type="hidden" name="bookId" value="@book.Id" />
                                        <input type="hidden" name="wishListId" value="@wl.Value" />

                                        <button type="submit" class="dropdown-item">@wl.Text</button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </div>
                    </div>
                } else {
                    <div class="alert alert-info border-0 shadow-sm">
                        <i class="bi bi-info-circle me-2"></i> Please login to purchase or review this book.
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row mt-5 mb-5">
        <div class="col-12"><hr /><h3 class="mb-4"><i class="bi bi-chat-left-text me-2"></i>Customer Reviews</h3></div>
        
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 bg-light">
                <div class="card-body">
                    <h5 class="card-title mb-3 text-dark fw-bold">Add a Review</h5>
                    @if (isAuthenticated) {
                        <form asp-controller="UserBook" asp-action="AddReview" method="post">
                            <input type="hidden" asp-for="NewReview.BookId" value="@book.Id" />
                            <div class="mb-3">
                                <label asp-for="NewReview.Rating" class="form-label fw-bold small">Your Rating</label>
                                <select asp-for="NewReview.Rating" class="form-select border-primary shadow-sm">
                                    @foreach (var val in Enum.GetValues<Rating>()) { 
                                        <option value="@val">@val.ToString()</option> 
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label asp-for="NewReview.Comment" class="form-label fw-bold small">Your Thoughts</label>
                                <textarea asp-for="NewReview.Comment" class="form-control border-primary shadow-sm" rows="4" placeholder="How did you like the story?"></textarea>
                                <span asp-validation-for="NewReview.Comment" class="text-danger small"></span>
                            </div>
                            <button type="submit" class="btn btn-primary w-100 shadow">Post My Review</button>
                        </form>
                    } else {
                        <div class="text-center py-3">
                            <p class="text-muted small">Log in to share your opinion with others.</p>
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm w-100">Login Now</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            @if (Model.Reviews != null && Model.Reviews.Any()) {
                <div class="list-group list-group-flush shadow-sm rounded border overflow-hidden">
                    @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt)) {
                        <div class="list-group-item p-4 bg-white" id="review-row-@review.Id">
                            
                            <div id="display-container-@review.Id">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <div class="mb-1">
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                <i class="bi bi-star-fill @(i < (int)review.Rating + 1 ? "text-warning" : "text-light border")"></i>
                                            }
                                            <span class="ms-2 fw-bold text-dark small">@review.Rating.ToString()</span>
                                        </div>
                                        <strong class="text-primary fs-5 d-block">@review.UserDisplayName</strong>
                                        <div class="text-muted small"><i class="bi bi-calendar3 me-1"></i>@review.CreatedAt.ToString("dd.MM.yyyy")</div>
                                    </div>

                                    @if (Model.CurrentUserId == review.UserId) {
                                        <button class="btn btn-primary btn-sm shadow-sm px-3" onclick="enableEdit(@review.Id)">
                                            <i class="bi bi-pencil-square me-1"></i> Edit my review
                                        </button>
                                    }
                                </div>
                                <div class="p-3 bg-light rounded-3 border-start border-4 border-primary">
                                    <p class="mb-0 text-dark italic">"@review.Comment"</p>
                                </div>
                            </div>

                            <div id="edit-form-container-@review.Id" style="display:none;" class="mt-2 p-4 bg-white border border-primary border-2 rounded shadow-lg">
                                <h5 class="text-primary mb-3 fw-bold"><i class="bi bi-pencil-square me-2"></i>Editing your review</h5>
                                <form asp-controller="UserBook" asp-action="UpdateReview" method="post">
                                    <input type="hidden" name="id" value="@review.Id" />
                                    <input type="hidden" name="bookId" value="@book.Id" />
                                    
                                    <div class="row g-3 mb-3">
                                        <div class="col-md-5">
                                            <label class="form-label fw-bold small">Change Rating:</label>
                                            <select name="rating" class="form-select border-primary shadow-sm">
                                                @foreach (var ratingVal in Enum.GetValues<Rating>()) {
                                                    <option value="@ratingVal" selected="@(ratingVal == review.Rating)">@ratingVal.ToString()</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label fw-bold small">Update Comment:</label>
                                            <textarea name="comment" class="form-control border-primary shadow-sm" rows="4">@review.Comment</textarea>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-end gap-2">
                                        <button type="button" class="btn btn-outline-secondary btn-sm px-3" onclick="cancelEdit(@review.Id)">Cancel</button>
                                        <button type="submit" class="btn btn-success btn-sm px-4 shadow-sm">Save Changes <i class="bi bi-check-lg ms-1"></i></button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            } else {
                <div class="text-center p-5 bg-light rounded border border-dashed text-muted shadow-sm">
                    <i class="bi bi-chat-square-dots fs-1 d-block mb-3"></i>
                    <p class="mb-0 fw-bold">No reviews yet.</p>
                    <p class="small">Be the first one to share your reading experience!</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function enableEdit(id) {
            document.getElementById('display-container-' + id).style.display = 'none';
            document.getElementById('edit-form-container-' + id).style.display = 'block';
        }
        function cancelEdit(id) {
            document.getElementById('display-container-' + id).style.display = 'block';
            document.getElementById('edit-form-container-' + id).style.display = 'none';
        }
    </script>
}

@functions {

    string GetImageSrc(string? base64)
    {
        if (string.IsNullOrWhiteSpace(base64)) return "https://via.placeholder.com/800x600?text=No+image";
        return base64.StartsWith("data:image") ? base64 : $"data:image/jpeg;base64,{base64}";
    }
}