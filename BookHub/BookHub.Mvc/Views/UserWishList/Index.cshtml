@model BookHub.Mvc.Models.User.WishList.UserWishListViewModel

@{
    ViewData["Title"] = "My wish list";
}

<h1>Wish list</h1>

@if (ViewData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Create new wish list</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
    <tr>
        <th>Wishlist name</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.WishListDetailViewModels)
    {
        <tr>
            <td>@item.Name</td>
            <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a></td>
            <td><a asp-action="DeleteWishList" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a></td>
        </tr>
    }
    </tbody>
</table>