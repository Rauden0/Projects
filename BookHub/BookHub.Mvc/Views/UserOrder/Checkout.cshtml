@using DataAccessLayer.Enums
@model BookHub.Mvc.Models.User.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<div class="container mt-4 mb-5">
    <h2 class="mb-4 text-center fw-bold text-uppercase">Finalize Your Order</h2>

    <form asp-action="Checkout" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CartId" />

        <div class="row">
            <div class="col-md-7">
                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-person-fill me-2"></i>Customer Information</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-bold"></label>
                                <input asp-for="FirstName" class="form-control" placeholder="John" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-bold"></label>
                                <input asp-for="LastName" class="form-control" placeholder="Doe" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold"></label>
                                <input asp-for="Email" class="form-control" placeholder="john@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold"></label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="+420..." />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-dark text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Delivery Address</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label asp-for="Street" class="form-label fw-bold"></label>
                            <input asp-for="Street" class="form-control" placeholder="Street name and number" />
                            <span asp-validation-for="Street" class="text-danger small"></span>
                        </div>
                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="City" class="form-label fw-bold"></label>
                                <input asp-for="City" class="form-control" placeholder="Prague" />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="PostalCode" class="form-label fw-bold"></label>
                                <input asp-for="PostalCode" class="form-control" placeholder="110 00" />
                                <span asp-validation-for="PostalCode" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-0">
                            <label asp-for="Country" class="form-label fw-bold"></label>
                            <input asp-for="Country" class="form-control bg-light" value="Czech Republic" readonly />
                            <span asp-validation-for="Country" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm mb-4 border-0">
                    <div class="card-header bg-secondary text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-credit-card-fill me-2"></i>Payment Method</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex flex-column gap-2">
                            @foreach (var method in Enum.GetValues<PaymentMethodEnum>())
                            {
                                <label class="form-check p-3 border rounded @(Model.PaymentMethod == method ? "border-primary bg-light" : "")" style="cursor: pointer;">
                                    <input class="form-check-input ms-0 me-3" type="radio" asp-for="PaymentMethod" 
                                           value="@method" id="pay-@method">
                                    <span class="form-check-label fw-bold">@method</span>
                                </label>
                            }
                        </div>
                        <span asp-validation-for="PaymentMethod" class="text-danger small d-block mt-2"></span>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card shadow-sm mb-4 border-info">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="bi bi-percent me-2"></i>Coupon Code</h5>
                    </div>
                    <div class="card-body">
                        <div class="input-group">
                            <input asp-for="CouponCode" class="form-control border-info" placeholder="ABC-123" />
                            <button type="submit" asp-action="ApplyCoupon" class="btn btn-info text-white px-4">Apply</button>
                        </div>
                        <span asp-validation-for="CouponCode" class="text-danger small d-block mt-2"></span>
                    </div>
                </div>

                <div class="card shadow border-primary position-sticky" style="top: 20px;">
                    <div class="card-header bg-light py-3">
                        <h5 class="mb-0 fw-bold">Order Summary</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="order-items-scroll mb-3" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var item in Model.CartItems)
                            {
                                var book = Model.Books.FirstOrDefault(b => b.Id == item.BookId);
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted small">@(book?.Name ?? "Book") <span class="fw-bold">x @item.Quantity</span></span>
                                    <span class="fw-bold">@((book?.Price ?? 0) * item.Quantity) Kč</span>
                                </div>
                            }
                        </div>
                        
                        <hr class="my-3" />
                        
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal:</span>
                            <span class="@(Model.Cart?.DiscountAmount > 0 ? "text-decoration-line-through text-danger" : "fw-bold")">
                                @Model.Cart?.RawTotalPrice.ToString("N2") Kč
                            </span>
                        </div>

                        @if (Model.Cart?.DiscountAmount > 0)
                        {
                            <div class="d-flex justify-content-between text-success fw-bold mb-2">
                                <span><i class="bi bi-tag-fill me-1"></i> Discount Applied:</span>
                                <span>- @Model.Cart.DiscountAmount.ToString("N2") Kč</span>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.CouponCode))
                            {
                                <div class="text-end mb-3">
                                    <span class="badge bg-success shadow-sm">Code: @Model.CouponCode</span>
                                </div>
                            }
                        }

                        <hr class="my-3" />

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <strong class="fs-5">Total Price:</strong>
                            <strong class="fs-4 text-primary">@Model.Cart?.FinalTotalPrice.ToString("N2") Kč</strong>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mt-3"></div>

                        <button type="submit" class="btn btn-success btn-lg w-100 py-3 shadow fw-bold text-uppercase">
                            Complete Order <i class="bi bi-arrow-right-circle ms-2"></i>
                        </button>
                        
                        <div class="text-center mt-3">
                            <a asp-controller="UserCart" asp-action="Index" class="text-decoration-none text-muted small">
                                <i class="bi bi-pencil-square me-1"></i> Edit shopping cart
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>